{
  "Axoloth Bento": {
    "prefix": "axo-bento",
    "description": "Axoloth responsive bento grid.",
    "body": [
      "<div class=\"axo-bento\">",
      "  <div class=\"axo-card axo-surface axo-rise\">$1</div>",
      "  <div class=\"axo-card axo-wide axo-pop\">$2</div>",
      "</div>"
    ]
  },
  "Axoloth Header": {
    "prefix": "axo-header",
    "description": "Axoloth four-slot app header.",
    "body": [
      "<header class=\"axo-header axo-header-grid axo-h-appbar axo-surface\">",
      "  <div class=\"axo-header-left\">$1</div>",
      "  <div class=\"axo-header-center\">",
      "    <label class=\"axo-searchbar\">",
      "      <span aria-hidden=\"true\">Search</span>",
      "      <input aria-label=\"Search\" placeholder=\"Search...\" />",
      "    </label>",
      "  </div>",
      "  <nav class=\"axo-header-nav\">$2</nav>",
      "  <div class=\"axo-header-right\">$3</div>",
      "</header>"
    ]
  },
  "Axoloth Sidebar": {
    "prefix": "axo-sidebar",
    "description": "Axoloth app shell with sidebar and main content.",
    "body": [
      "<div class=\"axo-shell axo-theme-dark\">",
      "  <aside class=\"axo-sidebar axo-sidebar-left axo-surface\">",
      "    <a class=\"axo-sidebar-item\" href=\"#dashboard\">Dashboard</a>",
      "    <a class=\"axo-sidebar-item\" href=\"#cards\">Cards</a>",
      "    <a class=\"axo-sidebar-item\" href=\"#settings\">Settings</a>",
      "  </aside>",
      "",
      "  <main class=\"axo-sidebar-main\">",
      "    <section class=\"axo-card axo-surface\">$1</section>",
      "  </main>",
      "</div>"
    ]
  },
  "Axoloth Hover Sidebar": {
    "prefix": "axo-sidebar-hover",
    "description": "Axoloth hover-expand sidebar rail.",
    "body": [
      "<div class=\"axo-shell axo-theme-dark\">",
      "  <aside class=\"axo-sidebar axo-sidebar-left axo-sidebar-rail axo-sidebar-hover axo-surface\">",
      "    <a class=\"axo-sidebar-item\" href=\"#dashboard\">Dashboard</a>",
      "    <a class=\"axo-sidebar-item\" href=\"#cards\">Cards</a>",
      "    <a class=\"axo-sidebar-item\" href=\"#settings\">Settings</a>",
      "  </aside>",
      "",
      "  <main class=\"axo-sidebar-main\">$1</main>",
      "</div>"
    ]
  },
  "Axoloth App Shell": {
    "prefix": "axo-app",
    "description": "Axoloth app shell grid with sidebar, header, main, and footer.",
    "body": [
      "<div class=\"axo-app axo-theme-dark\">",
      "  <aside class=\"axo-app-sidebar axo-sidebar axo-surface\">",
      "    <a class=\"axo-sidebar-item\" href=\"#dashboard\">Dashboard</a>",
      "    <a class=\"axo-sidebar-item\" href=\"#cards\">Cards</a>",
      "    <a class=\"axo-sidebar-item\" href=\"#settings\">Settings</a>",
      "  </aside>",
      "",
      "  <header class=\"axo-app-header axo-header axo-header-grid axo-surface\">$1</header>",
      "  <main class=\"axo-app-main\">$2</main>",
      "  <footer class=\"axo-app-footer axo-surface\">$3</footer>",
      "</div>"
    ]
  },
  "Axoloth Fixed Sidebar": {
    "prefix": "axo-sidebar-fixed",
    "description": "Axoloth fixed left sidebar with main content offset.",
    "body": [
      "<aside class=\"axo-sidebar axo-sidebar-fixed axo-sidebar-fixed-left axo-surface\">",
      "  <a class=\"axo-sidebar-item\" href=\"#dashboard\">Dashboard</a>",
      "  <a class=\"axo-sidebar-item\" href=\"#cards\">Cards</a>",
      "  <a class=\"axo-sidebar-item\" href=\"#settings\">Settings</a>",
      "</aside>",
      "",
      "<main class=\"axo-sidebar-main axo-sidebar-main-offset-left\">",
      "  <section class=\"axo-card axo-surface\">$1</section>",
      "</main>"
    ]
  },
  "Axoloth Fixed Rail Sidebar": {
    "prefix": "axo-sidebar-fixed-rail",
    "description": "Axoloth fixed hover-expand rail sidebar with rail offset.",
    "body": [
      "<aside class=\"axo-sidebar axo-sidebar-fixed axo-sidebar-fixed-left axo-sidebar-rail axo-sidebar-hover axo-surface\">",
      "  <a class=\"axo-sidebar-item\" href=\"#dashboard\">Dashboard</a>",
      "  <a class=\"axo-sidebar-item\" href=\"#cards\">Cards</a>",
      "  <a class=\"axo-sidebar-item\" href=\"#settings\">Settings</a>",
      "</aside>",
      "",
      "<main class=\"axo-sidebar-main axo-sidebar-main-offset-rail-left\">$1</main>"
    ]
  }
}

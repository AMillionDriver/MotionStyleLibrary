{
  "Axoloth Bento": {
    "prefix": "axo-bento",
    "description": "Axoloth responsive bento grid.",
    "body": [
      "<div className=\"axo-bento\">",
      "  <div className=\"axo-card axo-surface axo-rise\">$1</div>",
      "  <div className=\"axo-card axo-wide axo-pop\">$2</div>",
      "</div>"
    ]
  },
  "Axoloth Header": {
    "prefix": "axo-header",
    "description": "Axoloth four-slot app header.",
    "body": [
      "<header className=\"axo-header axo-header-grid axo-h-appbar axo-surface\">",
      "  <div className=\"axo-header-left\">$1</div>",
      "  <div className=\"axo-header-center\">",
      "    <label className=\"axo-searchbar\" htmlFor=\"axo-search\">",
      "      <span aria-hidden=\"true\">Search</span>",
      "      <input id=\"axo-search\" placeholder=\"Search...\" />",
      "    </label>",
      "  </div>",
      "  <nav className=\"axo-header-nav\">$2</nav>",
      "  <div className=\"axo-header-right\">$3</div>",
      "</header>"
    ]
  },
  "Axoloth Sidebar": {
    "prefix": "axo-sidebar",
    "description": "Axoloth app shell with sidebar and main content.",
    "body": [
      "<div className=\"axo-shell axo-theme-dark\">",
      "  <aside className=\"axo-sidebar axo-sidebar-left axo-surface\">",
      "    <a className=\"axo-sidebar-item\" href=\"#dashboard\">Dashboard</a>",
      "    <a className=\"axo-sidebar-item\" href=\"#cards\">Cards</a>",
      "    <a className=\"axo-sidebar-item\" href=\"#settings\">Settings</a>",
      "  </aside>",
      "",
      "  <main className=\"axo-sidebar-main\">",
      "    <section className=\"axo-card axo-surface\">$1</section>",
      "  </main>",
      "</div>"
    ]
  },
  "Axoloth Hover Sidebar": {
    "prefix": "axo-sidebar-hover",
    "description": "Axoloth hover-expand sidebar rail.",
    "body": [
      "<div className=\"axo-shell axo-theme-dark\">",
      "  <aside className=\"axo-sidebar axo-sidebar-left axo-sidebar-rail axo-sidebar-hover axo-surface\">",
      "    <a className=\"axo-sidebar-item\" href=\"#dashboard\">Dashboard</a>",
      "    <a className=\"axo-sidebar-item\" href=\"#cards\">Cards</a>",
      "    <a className=\"axo-sidebar-item\" href=\"#settings\">Settings</a>",
      "  </aside>",
      "",
      "  <main className=\"axo-sidebar-main\">$1</main>",
      "</div>"
    ]
  },
  "Axoloth App Shell": {
    "prefix": "axo-app",
    "description": "Axoloth app shell grid with sidebar, header, main, and footer.",
    "body": [
      "<div className=\"axo-app axo-theme-dark\">",
      "  <aside className=\"axo-app-sidebar axo-sidebar axo-surface\">",
      "    <a className=\"axo-sidebar-item\" href=\"#dashboard\">Dashboard</a>",
      "    <a className=\"axo-sidebar-item\" href=\"#cards\">Cards</a>",
      "    <a className=\"axo-sidebar-item\" href=\"#settings\">Settings</a>",
      "  </aside>",
      "",
      "  <header className=\"axo-app-header axo-header axo-header-grid axo-surface\">$1</header>",
      "  <main className=\"axo-app-main\">$2</main>",
      "  <footer className=\"axo-app-footer axo-surface\">$3</footer>",
      "</div>"
    ]
  },
  "Axoloth Fixed Sidebar": {
    "prefix": "axo-sidebar-fixed",
    "description": "Axoloth fixed left sidebar with main content offset.",
    "body": [
      "<aside className=\"axo-sidebar axo-sidebar-fixed axo-sidebar-fixed-left axo-surface\">",
      "  <a className=\"axo-sidebar-item\" href=\"#dashboard\">Dashboard</a>",
      "  <a className=\"axo-sidebar-item\" href=\"#cards\">Cards</a>",
      "  <a className=\"axo-sidebar-item\" href=\"#settings\">Settings</a>",
      "</aside>",
      "",
      "<main className=\"axo-sidebar-main axo-sidebar-main-offset-left\">",
      "  <section className=\"axo-card axo-surface\">$1</section>",
      "</main>"
    ]
  },
  "Axoloth Fixed Rail Sidebar": {
    "prefix": "axo-sidebar-fixed-rail",
    "description": "Axoloth fixed hover-expand rail sidebar with rail offset.",
    "body": [
      "<aside className=\"axo-sidebar axo-sidebar-fixed axo-sidebar-fixed-left axo-sidebar-rail axo-sidebar-hover axo-surface\">",
      "  <a className=\"axo-sidebar-item\" href=\"#dashboard\">Dashboard</a>",
      "  <a className=\"axo-sidebar-item\" href=\"#cards\">Cards</a>",
      "  <a className=\"axo-sidebar-item\" href=\"#settings\">Settings</a>",
      "</aside>",
      "",
      "<main className=\"axo-sidebar-main axo-sidebar-main-offset-rail-left\">$1</main>"
    ]
  },
  "Axoloth Page": {
    "prefix": "axo-page",
    "description": "Axoloth semantic page wrapper with container and section.",
    "body": [
      "<main className=\"axo-page axo-theme-light\">",
      "  <section className=\"axo-container axo-section\">",
      "    $1",
      "  </section>",
      "</main>"
    ]
  },
  "Axoloth Nav": {
    "prefix": "axo-nav",
    "description": "Axoloth semantic navigation list.",
    "body": [
      "<nav className=\"axo-nav\" aria-label=\"$1\">",
      "  <ul className=\"axo-nav-list\">",
      "    <li><a className=\"axo-link\" href=\"#intro\">Intro</a></li>",
      "    <li><a className=\"axo-link\" href=\"#cards\">Cards</a></li>",
      "    <li><a className=\"axo-link\" href=\"#contact\">Contact</a></li>",
      "  </ul>",
      "</nav>"
    ]
  },
  "Axoloth Form": {
    "prefix": "axo-form",
    "description": "Axoloth semantic vertical form.",
    "body": [
      "<form className=\"axo-form axo-card axo-surface\">",
      "  <label className=\"axo-field\">",
      "    <span className=\"axo-label\">Name</span>",
      "    <input className=\"axo-input\" name=\"name\" />",
      "  </label>",
      "",
      "  <label className=\"axo-field\">",
      "    <span className=\"axo-label\">Message</span>",
      "    <textarea className=\"axo-input\" name=\"message\"></textarea>",
      "  </label>",
      "",
      "  <button className=\"axo-button\" type=\"submit\">Send</button>",
      "</form>"
    ]
  },
  "Axoloth Form Grid": {
    "prefix": "axo-form-grid",
    "description": "Axoloth semantic responsive form grid.",
    "body": [
      "<form className=\"axo-form-grid axo-card axo-surface\">",
      "  <label className=\"axo-field\">",
      "    <span className=\"axo-label\">First name</span>",
      "    <input className=\"axo-input\" name=\"firstName\" />",
      "  </label>",
      "",
      "  <label className=\"axo-field\">",
      "    <span className=\"axo-label\">Last name</span>",
      "    <input className=\"axo-input\" name=\"lastName\" />",
      "  </label>",
      "",
      "  <button className=\"axo-button axo-button-block\" type=\"submit\">Save</button>",
      "</form>"
    ]
  },
  "Axoloth Alert": {
    "prefix": "axo-alert",
    "description": "Axoloth neutral alert structure.",
    "body": [
      "<div className=\"axo-alert axo-surface\" role=\"status\">",
      "  <strong className=\"axo-alert-title\">$1</strong>",
      "  <p>$2</p>",
      "</div>"
    ]
  },
  "Axoloth Empty State": {
    "prefix": "axo-empty",
    "description": "Axoloth centered empty-state structure.",
    "body": [
      "<section className=\"axo-empty axo-surface\">",
      "  <span className=\"axo-empty-icon\" aria-hidden=\"true\">$1</span>",
      "  <h2 className=\"axo-empty-title\">$2</h2>",
      "  <p className=\"axo-empty-description\">$3</p>",
      "  <button className=\"axo-button\" type=\"button\">$4</button>",
      "</section>"
    ]
  },
  "Axoloth Table": {
    "prefix": "axo-table",
    "description": "Axoloth responsive semantic data table.",
    "body": [
      "<div className=\"axo-table-wrap axo-surface\">",
      "  <table className=\"axo-table axo-table-sticky\">",
      "    <thead>",
      "      <tr><th scope=\"col\">$1</th><th scope=\"col\">$2</th></tr>",
      "    </thead>",
      "    <tbody>",
      "      <tr><td>$3</td><td><span className=\"axo-badge\">$4</span></td></tr>",
      "    </tbody>",
      "  </table>",
      "</div>"
    ]
  },
  "Axoloth Container Bento": {
    "prefix": "axo-bento-container",
    "description": "Axoloth Bento that responds to its wrapper width.",
    "body": [
      "<div className=\"axo-container-query\">",
      "  <section className=\"axo-bento axo-container-responsive\">",
      "    <article className=\"axo-card axo-surface axo-wide\">$1</article>",
      "    <article className=\"axo-card axo-surface axo-square\">$2</article>",
      "  </section>",
      "</div>"
    ]
  },
  "Axoloth Auto Grid": {
    "prefix": "axo-auto-grid",
    "description": "Axoloth auto-fitting grid without breakpoint classes.",
    "body": [
      "<section className=\"axo-auto-grid\">",
      "  <article className=\"axo-card axo-surface\">$1</article>",
      "  <article className=\"axo-card axo-surface\">$2</article>",
      "  <article className=\"axo-card axo-surface\">$3</article>",
      "</section>"
    ]
  },
  "Axoloth Switcher": {
    "prefix": "axo-switcher",
    "description": "Axoloth row-to-stack responsive primitive.",
    "body": [
      "<section className=\"axo-switcher\">",
      "  <article className=\"axo-card axo-surface\">$1</article>",
      "  <article className=\"axo-card axo-surface\">$2</article>",
      "</section>"
    ]
  },
  "Axoloth Cover": {
    "prefix": "axo-cover",
    "description": "Axoloth full-height centered section.",
    "body": [
      "<section className=\"axo-cover\">",
      "  <div className=\"axo-center axo-stack\">",
      "    <h1>$1</h1>",
      "    <p>$2</p>",
      "  </div>",
      "</section>"
    ]
  },
  "Axoloth Reel": {
    "prefix": "axo-reel",
    "description": "Axoloth horizontal snap-scrolling row.",
    "body": [
      "<section className=\"axo-reel\" aria-label=\"$1\">",
      "  <article className=\"axo-card axo-surface\">$2</article>",
      "  <article className=\"axo-card axo-surface\">$3</article>",
      "  <article className=\"axo-card axo-surface\">$4</article>",
      "</section>"
    ]
  },
  "Axoloth Progress": {
    "prefix": "axo-progress",
    "description": "Accessible Axoloth progress indicator.",
    "body": [
      "<div",
      "  className=\"axo-progress\"",
      "  role=\"progressbar\"",
      "  aria-label=\"$1\"",
      "  aria-valuemin=\"0\"",
      "  aria-valuemax=\"100\"",
      "  aria-valuenow={$2}",
      "  style={{ inlineSize: '$2%' }}",
      ">",
      "  <span className=\"axo-progress-bar\" />",
      "</div>"
    ]
  },
  "Axoloth Skeleton": {
    "prefix": "axo-skeleton",
    "description": "Accessible decorative Axoloth loading skeletons.",
    "body": [
      "<div className=\"axo-stack\" aria-hidden=\"true\">",
      "  <span className=\"axo-skeleton axo-skeleton-circle\" />",
      "  <span className=\"axo-skeleton axo-skeleton-text\" />",
      "  <span className=\"axo-skeleton axo-skeleton-text\" style={{ inlineSize: '14rem' }} />",
      "</div>"
    ]
  },
  "Axoloth Validation Form": {
    "prefix": "axo-validation-form",
    "description": "Axoloth form field with accessible invalid state.",
    "body": [
      "<form className=\"axo-form axo-card axo-surface\">",
      "  <label className=\"axo-field\">",
      "    <span className=\"axo-label axo-required\">$1</span>",
      "    <input",
      "      className=\"axo-input axo-invalid\"",
      "      name=\"$2\"",
      "      aria-invalid=\"true\"",
      "      aria-describedby=\"$2-error\"",
      "      required",
      "    />",
      "    <small className=\"axo-error\" id=\"$2-error\">$3</small>",
      "  </label>",
      "</form>"
    ]
  },
  "Axoloth Choice Controls": {
    "prefix": "axo-choice-controls",
    "description": "Native checkbox, radio, and switch controls with Axoloth layout.",
    "body": [
      "<div className=\"axo-stack\">",
      "  <label className=\"axo-checkbox\"><input type=\"checkbox\" /> <span>$1</span></label>",
      "  <label className=\"axo-radio\"><input type=\"radio\" name=\"$2\" /> <span>$3</span></label>",
      "  <label className=\"axo-switch\"><input type=\"checkbox\" /> <span>$4</span></label>",
      "</div>"
    ]
  },
  "Axoloth Skip Link": {
    "prefix": "axo-skip-link",
    "description": "Keyboard skip link and main-content target.",
    "body": [
      "<a className=\"axo-skip-link\" href=\"#main-content\">Skip to main content</a>",
      "<main id=\"main-content\" tabIndex={-1}>$1</main>"
    ]
  },
  "Axoloth Offcanvas Sidebar": {
    "prefix": "axo-sidebar-offcanvas",
    "description": "Accessible off-canvas sidebar for Axoloth Behavior.",
    "body": [
      "<button",
      "  className=\"axo-button\"",
      "  type=\"button\"",
      "  data-axo-toggle=\"$1-sidebar\"",
      "  aria-controls=\"$1-sidebar\"",
      "  aria-expanded=\"false\"",
      ">",
      "  Open menu",
      "</button>",
      "",
      "<aside",
      "  id=\"$1-sidebar\"",
      "  className=\"axo-sidebar axo-sidebar-offcanvas axo-surface\"",
      "  data-axo-id=\"$1-sidebar\"",
      "  role=\"dialog\"",
      "  aria-modal=\"true\"",
      "  aria-label=\"$2 navigation\"",
      "  aria-hidden=\"true\"",
      ">",
      "  <button className=\"axo-button\" type=\"button\" data-axo-dismiss=\"$1-sidebar\">Close</button>",
      "  <a className=\"axo-sidebar-item axo-link\" href=\"#$3\">$4</a>",
      "</aside>",
      "",
      "<div className=\"axo-sidebar-backdrop\" data-axo-dismiss=\"$1-sidebar\" aria-hidden=\"true\" />"
    ]
  },
  "Axoloth Dialog": {
    "prefix": "axo-dialog",
    "description": "Accessible modal dialog for Axoloth Behavior.",
    "body": [
      "<button",
      "  className=\"axo-button\"",
      "  type=\"button\"",
      "  data-axo-dialog-toggle=\"$1-dialog\"",
      "  aria-controls=\"$1-dialog\"",
      "  aria-expanded=\"false\"",
      ">",
      "  Open dialog",
      "</button>",
      "",
      "<div",
      "  id=\"$1-dialog\"",
      "  className=\"axo-dialog\"",
      "  data-axo-dialog-id=\"$1-dialog\"",
      "  aria-labelledby=\"$1-dialog-title\"",
      "  aria-hidden=\"true\"",
      ">",
      "  <div className=\"axo-dialog-backdrop\" data-axo-dialog-dismiss=\"$1-dialog\" aria-hidden=\"true\" />",
      "  <section className=\"axo-dialog-panel axo-surface\">",
      "    <header className=\"axo-dialog-header\">",
      "      <h2 id=\"$1-dialog-title\">$2</h2>",
      "      <button className=\"axo-button\" type=\"button\" data-axo-dialog-dismiss=\"$1-dialog\">Close</button>",
      "    </header>",
      "    <div className=\"axo-dialog-body\">$3</div>",
      "    <footer className=\"axo-dialog-footer\">",
      "      <button className=\"axo-button\" type=\"button\" data-axo-dialog-dismiss=\"$1-dialog\">Cancel</button>",
      "      <button className=\"axo-button\" type=\"button\">$4</button>",
      "    </footer>",
      "  </section>",
      "</div>"
    ]
  },
  "Axoloth Tabs": {
    "prefix": "axo-tabs",
    "description": "Accessible Axoloth tabs prepared for initTabs.",
    "body": [
      "<div id=\"$1-tabs\" className=\"axo-tabs\" data-axo-tabs>",
      "  <div className=\"axo-tab-list\" aria-label=\"$2 sections\">",
      "    <button className=\"axo-tab\" type=\"button\" data-axo-tab=\"$3\" aria-selected=\"true\">$4</button>",
      "    <button className=\"axo-tab\" type=\"button\" data-axo-tab=\"$5\">$6</button>",
      "  </div>",
      "  <section className=\"axo-tab-panel axo-card axo-surface\" data-axo-tab-panel=\"$3\">$7</section>",
      "  <section className=\"axo-tab-panel axo-card axo-surface\" data-axo-tab-panel=\"$5\">$8</section>",
      "</div>"
    ]
  },
  "Axoloth Accordion": {
    "prefix": "axo-accordion",
    "description": "Accessible Axoloth accordion prepared for initAccordion.",
    "body": [
      "<div id=\"$1-accordion\" className=\"axo-accordion\" data-axo-accordion>",
      "  <section className=\"axo-accordion-item axo-surface\">",
      "    <h3>",
      "      <button className=\"axo-accordion-trigger\" type=\"button\" data-axo-accordion-trigger=\"$2\" aria-expanded=\"true\">",
      "        $3 <span className=\"axo-accordion-indicator\" aria-hidden=\"true\">+</span>",
      "      </button>",
      "    </h3>",
      "    <div className=\"axo-accordion-panel\" data-axo-accordion-panel=\"$2\">$4</div>",
      "  </section>",
      "  <section className=\"axo-accordion-item axo-surface\">",
      "    <h3>",
      "      <button className=\"axo-accordion-trigger\" type=\"button\" data-axo-accordion-trigger=\"$5\">",
      "        $6 <span className=\"axo-accordion-indicator\" aria-hidden=\"true\">+</span>",
      "      </button>",
      "    </h3>",
      "    <div className=\"axo-accordion-panel\" data-axo-accordion-panel=\"$5\">$7</div>",
      "  </section>",
      "</div>"
    ]
  },
  "Axoloth Dropdown": {
    "prefix": "axo-dropdown",
    "description": "Accessible Axoloth menu prepared for initDropdown.",
    "body": [
      "<div id=\"$1-dropdown\" className=\"axo-dropdown axo-dropdown-end\" data-axo-dropdown>",
      "  <button",
      "    className=\"axo-button axo-dropdown-trigger\"",
      "    type=\"button\"",
      "    data-axo-dropdown-toggle=\"$2\"",
      "  >",
      "    $3",
      "  </button>",
      "  <div className=\"axo-dropdown-menu axo-surface\" data-axo-dropdown-menu=\"$2\" hidden>",
      "    <button className=\"axo-dropdown-item\" type=\"button\" data-axo-dropdown-item>$4</button>",
      "    <button className=\"axo-dropdown-item\" type=\"button\" data-axo-dropdown-item>$5</button>",
      "  </div>",
      "</div>"
    ]
  },
  "Axoloth Toast Region": {
    "prefix": "axo-toast-region",
    "description": "Accessible notification region prepared for initToast.",
    "body": [
      "<div",
      "  id=\"$1-notifications\"",
      "  className=\"axo-toast-region axo-toast-region-top-end\"",
      "  data-axo-toast-region",
      "  aria-label=\"$2 Notifications\"",
      "/>"
    ]
  }
}

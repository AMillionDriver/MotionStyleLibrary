{
  "Axoloth Bento": {
    "prefix": "axo-bento",
    "description": "Axoloth responsive bento grid.",
    "body": [
      "<div className=\"axo-bento\">",
      "  <div className=\"axo-card axo-surface axo-rise\">$1</div>",
      "  <div className=\"axo-card axo-wide axo-pop\">$2</div>",
      "</div>"
    ]
  },
  "Axoloth Header": {
    "prefix": "axo-header",
    "description": "Axoloth four-slot app header.",
    "body": [
      "<header className=\"axo-header axo-header-grid axo-h-appbar axo-surface\">",
      "  <div className=\"axo-header-left\">$1</div>",
      "  <div className=\"axo-header-center\">",
      "    <label className=\"axo-searchbar\" htmlFor=\"axo-search\">",
      "      <span aria-hidden=\"true\">Search</span>",
      "      <input id=\"axo-search\" placeholder=\"Search...\" />",
      "    </label>",
      "  </div>",
      "  <nav className=\"axo-header-nav\">$2</nav>",
      "  <div className=\"axo-header-right\">$3</div>",
      "</header>"
    ]
  },
  "Axoloth Sidebar": {
    "prefix": "axo-sidebar",
    "description": "Axoloth app shell with sidebar and main content.",
    "body": [
      "<div className=\"axo-shell axo-theme-dark\">",
      "  <aside className=\"axo-sidebar axo-sidebar-left axo-surface\">",
      "    <a className=\"axo-sidebar-item\" href=\"#dashboard\">Dashboard</a>",
      "    <a className=\"axo-sidebar-item\" href=\"#cards\">Cards</a>",
      "    <a className=\"axo-sidebar-item\" href=\"#settings\">Settings</a>",
      "  </aside>",
      "",
      "  <main className=\"axo-sidebar-main\">",
      "    <section className=\"axo-card axo-surface\">$1</section>",
      "  </main>",
      "</div>"
    ]
  },
  "Axoloth Hover Sidebar": {
    "prefix": "axo-sidebar-hover",
    "description": "Axoloth hover-expand sidebar rail.",
    "body": [
      "<div className=\"axo-shell axo-theme-dark\">",
      "  <aside className=\"axo-sidebar axo-sidebar-left axo-sidebar-rail axo-sidebar-hover axo-surface\">",
      "    <a className=\"axo-sidebar-item\" href=\"#dashboard\">Dashboard</a>",
      "    <a className=\"axo-sidebar-item\" href=\"#cards\">Cards</a>",
      "    <a className=\"axo-sidebar-item\" href=\"#settings\">Settings</a>",
      "  </aside>",
      "",
      "  <main className=\"axo-sidebar-main\">$1</main>",
      "</div>"
    ]
  }
}

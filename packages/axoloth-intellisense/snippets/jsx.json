{
  "Axoloth Bento": {
    "prefix": "axo-bento",
    "description": "Axoloth responsive bento grid.",
    "body": [
      "<div className=\"axo-bento\">",
      "  <div className=\"axo-card axo-surface axo-rise\">$1</div>",
      "  <div className=\"axo-card axo-wide axo-pop\">$2</div>",
      "</div>"
    ]
  },
  "Axoloth Header": {
    "prefix": "axo-header",
    "description": "Axoloth four-slot app header.",
    "body": [
      "<header className=\"axo-header axo-header-grid axo-h-appbar axo-surface\">",
      "  <div className=\"axo-header-left\">$1</div>",
      "  <div className=\"axo-header-center\">",
      "    <label className=\"axo-searchbar\" htmlFor=\"axo-search\">",
      "      <span aria-hidden=\"true\">Search</span>",
      "      <input id=\"axo-search\" placeholder=\"Search...\" />",
      "    </label>",
      "  </div>",
      "  <nav className=\"axo-header-nav\">$2</nav>",
      "  <div className=\"axo-header-right\">$3</div>",
      "</header>"
    ]
  },
  "Axoloth Sidebar": {
    "prefix": "axo-sidebar",
    "description": "Axoloth app shell with sidebar and main content.",
    "body": [
      "<div className=\"axo-shell axo-theme-dark\">",
      "  <aside className=\"axo-sidebar axo-sidebar-left axo-surface\">",
      "    <a className=\"axo-sidebar-item\" href=\"#dashboard\">Dashboard</a>",
      "    <a className=\"axo-sidebar-item\" href=\"#cards\">Cards</a>",
      "    <a className=\"axo-sidebar-item\" href=\"#settings\">Settings</a>",
      "  </aside>",
      "",
      "  <main className=\"axo-sidebar-main\">",
      "    <section className=\"axo-card axo-surface\">$1</section>",
      "  </main>",
      "</div>"
    ]
  },
  "Axoloth Hover Sidebar": {
    "prefix": "axo-sidebar-hover",
    "description": "Axoloth hover-expand sidebar rail.",
    "body": [
      "<div className=\"axo-shell axo-theme-dark\">",
      "  <aside className=\"axo-sidebar axo-sidebar-left axo-sidebar-rail axo-sidebar-hover axo-surface\">",
      "    <a className=\"axo-sidebar-item\" href=\"#dashboard\">Dashboard</a>",
      "    <a className=\"axo-sidebar-item\" href=\"#cards\">Cards</a>",
      "    <a className=\"axo-sidebar-item\" href=\"#settings\">Settings</a>",
      "  </aside>",
      "",
      "  <main className=\"axo-sidebar-main\">$1</main>",
      "</div>"
    ]
  },
  "Axoloth App Shell": {
    "prefix": "axo-app",
    "description": "Axoloth app shell grid with sidebar, header, main, and footer.",
    "body": [
      "<div className=\"axo-app axo-theme-dark\">",
      "  <aside className=\"axo-app-sidebar axo-sidebar axo-surface\">",
      "    <a className=\"axo-sidebar-item\" href=\"#dashboard\">Dashboard</a>",
      "    <a className=\"axo-sidebar-item\" href=\"#cards\">Cards</a>",
      "    <a className=\"axo-sidebar-item\" href=\"#settings\">Settings</a>",
      "  </aside>",
      "",
      "  <header className=\"axo-app-header axo-header axo-header-grid axo-surface\">$1</header>",
      "  <main className=\"axo-app-main\">$2</main>",
      "  <footer className=\"axo-app-footer axo-surface\">$3</footer>",
      "</div>"
    ]
  },
  "Axoloth Fixed Sidebar": {
    "prefix": "axo-sidebar-fixed",
    "description": "Axoloth fixed left sidebar with main content offset.",
    "body": [
      "<aside className=\"axo-sidebar axo-sidebar-fixed axo-sidebar-fixed-left axo-surface\">",
      "  <a className=\"axo-sidebar-item\" href=\"#dashboard\">Dashboard</a>",
      "  <a className=\"axo-sidebar-item\" href=\"#cards\">Cards</a>",
      "  <a className=\"axo-sidebar-item\" href=\"#settings\">Settings</a>",
      "</aside>",
      "",
      "<main className=\"axo-sidebar-main axo-sidebar-main-offset-left\">",
      "  <section className=\"axo-card axo-surface\">$1</section>",
      "</main>"
    ]
  },
  "Axoloth Fixed Rail Sidebar": {
    "prefix": "axo-sidebar-fixed-rail",
    "description": "Axoloth fixed hover-expand rail sidebar with rail offset.",
    "body": [
      "<aside className=\"axo-sidebar axo-sidebar-fixed axo-sidebar-fixed-left axo-sidebar-rail axo-sidebar-hover axo-surface\">",
      "  <a className=\"axo-sidebar-item\" href=\"#dashboard\">Dashboard</a>",
      "  <a className=\"axo-sidebar-item\" href=\"#cards\">Cards</a>",
      "  <a className=\"axo-sidebar-item\" href=\"#settings\">Settings</a>",
      "</aside>",
      "",
      "<main className=\"axo-sidebar-main axo-sidebar-main-offset-rail-left\">$1</main>"
    ]
  },
  "Axoloth Page": {
    "prefix": "axo-page",
    "description": "Axoloth semantic page wrapper with container and section.",
    "body": [
      "<main className=\"axo-page axo-theme-light\">",
      "  <section className=\"axo-container axo-section\">",
      "    $1",
      "  </section>",
      "</main>"
    ]
  },
  "Axoloth Nav": {
    "prefix": "axo-nav",
    "description": "Axoloth semantic navigation list.",
    "body": [
      "<nav className=\"axo-nav\" aria-label=\"$1\">",
      "  <ul className=\"axo-nav-list\">",
      "    <li><a className=\"axo-link\" href=\"#intro\">Intro</a></li>",
      "    <li><a className=\"axo-link\" href=\"#cards\">Cards</a></li>",
      "    <li><a className=\"axo-link\" href=\"#contact\">Contact</a></li>",
      "  </ul>",
      "</nav>"
    ]
  },
  "Axoloth Form": {
    "prefix": "axo-form",
    "description": "Axoloth semantic vertical form.",
    "body": [
      "<form className=\"axo-form axo-card axo-surface\">",
      "  <label className=\"axo-field\">",
      "    <span className=\"axo-label\">Name</span>",
      "    <input className=\"axo-input\" name=\"name\" />",
      "  </label>",
      "",
      "  <label className=\"axo-field\">",
      "    <span className=\"axo-label\">Message</span>",
      "    <textarea className=\"axo-input\" name=\"message\"></textarea>",
      "  </label>",
      "",
      "  <button className=\"axo-button\" type=\"submit\">Send</button>",
      "</form>"
    ]
  },
  "Axoloth Form Grid": {
    "prefix": "axo-form-grid",
    "description": "Axoloth semantic responsive form grid.",
    "body": [
      "<form className=\"axo-form-grid axo-card axo-surface\">",
      "  <label className=\"axo-field\">",
      "    <span className=\"axo-label\">First name</span>",
      "    <input className=\"axo-input\" name=\"firstName\" />",
      "  </label>",
      "",
      "  <label className=\"axo-field\">",
      "    <span className=\"axo-label\">Last name</span>",
      "    <input className=\"axo-input\" name=\"lastName\" />",
      "  </label>",
      "",
      "  <button className=\"axo-button axo-button-block\" type=\"submit\">Save</button>",
      "</form>"
    ]
  }
}
